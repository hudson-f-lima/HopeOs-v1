# Servidor local do backend
PORT=3333
NODE_ENV=development

# Pasta de dados do modo local
DATA_DIR=../data

# Supabase real. Nunca colocar service role no frontend.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLE_AQUI_SOMENTE_NO_BACKEND

# Credencial exigida em todas as rotas /api/* (exceto /api/health).
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sem esta variavel o backend responde 503 e nao serve dados (fail closed).
API_ACCESS_TOKEN=COLE_AQUI_UM_TOKEN_LONGO_E_ALEATORIO

# ID da empresa usada como contexto padrao no repo
DEFAULT_EMPRESA_ID=00000000-0000-0000-0000-000000000001

# Origens liberadas para CORS no backend local
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5500,null
